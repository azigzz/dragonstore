DISCORD_TOKEN=COLE_O_TOKEN_DO_BOT_AQUI
CLIENT_ID=COLE_O_CLIENT_ID_AQUI
# Identificador unico desta instalacao. Use outro valor em cada loja.
STORE_INSTANCE_ID=primary
# Impede esta instancia de responder em outro servidor por engano.
STRICT_GUILD_ISOLATION=true
# Usuario que pode gerar/restaurar clone completo alem do dono do servidor.
CEO_USER_ID=COLE_SEU_ID_DO_DISCORD
CLIENT_SECRET=COLE_O_CLIENT_SECRET_AQUI
REDIRECT_URI=https://seu-bot.onrender.com/auth/discord/callback
GUILD_ID=COLE_O_ID_DO_SERVIDOR_AQUI
MAIN_GUILD_ID=COLE_O_ID_DO_SERVIDOR_PRINCIPAL_AQUI
CLIENT_ROLE_ID=COLE_O_ID_DO_CARGO_CLIENTE_AQUI
BACKUP_GUILD_ID=COLE_O_ID_DO_SERVIDOR_RESERVA_AQUI
ADMIN_ROLE_ID=COLE_O_ID_DO_CARGO_ADMIN_AQUI
RESELLER_ROLE_ID=COLE_O_ID_DO_CARGO_PREMIUM_AQUI
CUSTOMER_ROLE_ID=COLE_O_ID_DO_CARGO_CLIENTE_AQUI
CART_OPEN_CATEGORY_ID=COLE_O_ID_DA_CATEGORIA_DE_CARRINHOS
CLOSED_CATEGORY_ID=COLE_O_ID_DA_CATEGORIA_DE_FINALIZADOS
TICKET_OPEN_CATEGORY_ID=COLE_O_ID_DA_CATEGORIA_DE_TICKETS
TICKET_PANEL_CHANNEL_ID=COLE_O_ID_DO_CANAL_DO_PAINEL_DE_SUPORTE
PORT=10000
ENABLE_MESSAGE_CONTENT_INTENT=true
PUBLIC_STORE_API_TOKEN=GERE_UM_TOKEN_FORTE
PUBLIC_STORE_NAME=Nome da Loja
PUBLIC_STORE_GUILD_ID=COLE_O_ID_DO_SERVIDOR_AQUI
PUBLIC_STORE_CORS_ORIGIN=https://seu-site.vercel.app
PUBLIC_STORE_SCAN_CHANNELS=true
DISCORD_INVITE_URL=https://discord.gg/seu-convite
# 1h30 para carrinhos finalizados; 10s para cancelados.
CLOSED_CART_DELETE_SECONDS=5400
CANCELLED_CART_DELETE_SECONDS=10
DATABASE_URL=postgres://usuario:senha@host/db
DATABASE_SSL=true
# Use true somente se o provedor exigir handshake TLS direto.
DATABASE_DIRECT_TLS=false
# Opcional: certificado CA da Aiven/Neon em Base64 para validar TLS.
# DATABASE_CA_CERT_BASE64=
# Opcional. Sem isso, o prefixo e gerado a partir de STORE_INSTANCE_ID.
# BOT_DB_PREFIX=dragon-store:bot:dragon-primary
PIX_ENCRYPTION_KEY=gere_uma_chave_longa_para_migrar_pix
# IDs Discord autorizados a configurar Pix/estoque e aprovar pagamentos manuais.
# Separe varios proprietarios por virgula.
BOT_OWNER_IDS=COLE_SEU_ID_DO_DISCORD
# Token direto do PagBank. Nao use Client ID/Secret ou Connect.
PAGBANK_TOKEN=COLE_O_TOKEN_PAGBANK_AQUI
PAGBANK_ENV=sandbox
PAGBANK_WEBHOOK_URL=https://savio-store.onrender.com/webhooks/pagbank
PAGBANK_HOMOLOGATION_EXPORT=false
PAYMENT_PROVIDER=mercadopago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-COLE_O_ACCESS_TOKEN_DE_PRODUCAO
MERCADOPAGO_WEBHOOK_URL=https://savio-store.onrender.com/webhooks/mercadopago
MERCADOPAGO_WEBHOOK_SECRET=COLE_A_ASSINATURA_SECRETA_DO_WEBHOOK
# Consulta pagamentos pendentes mesmo se o webhook atrasar ou falhar.
MERCADOPAGO_RECONCILE_INTERVAL_SECONDS=20
MERCADOPAGO_RECONCILE_BATCH_SIZE=15
MERCADOPAGO_SETTLEMENT_GRACE_MINUTES=5
MERCADOPAGO_ERROR_GRACE_MINUTES=30
# Gere 32 bytes: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
STOCK_ENCRYPTION_KEY=GERE_UMA_CHAVE_BASE64_DE_32_BYTES
MANUAL_PIX_RESERVATION_MINUTES=30
SITE_ADMIN_AUDIT_KV_KEY=dragon-store:site-admin-audit
