{
  "name": "discord-sales-bot-config-discord",
  "version": "2.3.0",
  "description": "Bot de vendas Discord com configurador dentro do Discord.",
  "main": "src/index.js",
  "scripts": {
    "check": "node --check src/index.js && node --check deploy-commands.js",
    "deploy": "node deploy-commands.js",
